---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { campings } from "@/lib/camping";

export function getStaticPaths() {
    return ["id", "en"].flatMap((locale) =>
        campings.map((camping) => ({
            params: { locale, id: camping.id },
        })),
    );
}

const { id } = Astro.params;
---

<BaseLayout title={`Camping ${id}`}>
    <section class="px-6 pt-32 pb-20">
        <div class="mx-auto max-w-6xl">
            <p class="text-dark/50">
                Camping detail page for: <strong>{id}</strong>
            </p>
            <p class="mt-4 text-dark/40">
                Content akan ditampilkan di sini — menunggu data dan foto.
            </p>
        </div>
    </section>
</BaseLayout>
