---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
---

<BaseLayout title="Villa">
  <section class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-6xl">
      <SectionHeader
        label="Akomodasi"
        title="Villa Kami"
        subtitle="10 villa di tengah hutan, masing-masing dengan pemandangan dan pengalaman unik."
      />
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <p class="col-span-full text-center text-dark/50">Villa cards akan ditampilkan di sini — menunggu data dan foto.</p>
      </div>
    </div>
  </section>
</BaseLayout>
