---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
---

<BaseLayout title="Galeri">
  <section class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-6xl">
      <SectionHeader
        label="Galeri"
        title="Moments at Kasumi"
        subtitle="Follow us and tag @kasumi_resort to be featured!"
      />
      <div class="flex flex-wrap justify-center gap-4">
        <p class="text-dark/50">Floating photo gallery akan ditampilkan di sini — menunggu foto dan aset.</p>
      </div>
    </div>
  </section>
</BaseLayout>
