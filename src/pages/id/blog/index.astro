---
/**
 * Blog Index — /id/blog
 * Lists blog posts with filter chips UI (placeholder).
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Badge from '../../../components/ui/Badge.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="Stories, tips & nature information from Kasumi Resort.">
  <section class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-4xl">
      <SectionHeader
        title="Stories, Tips & Nature Information"
        subtitle="Cerita, tips, dan informasi seputar alam dari Kasumi Resort."
        align="left"
      />

      <!-- Filter chips (placeholder) -->
      <div class="mb-10 flex flex-wrap gap-2">
        <Badge label="Semua" variant="secondary" />
        <Badge label="Tips Berkemah" />
        <Badge label="Wisata Sukabumi" />
        <Badge label="Update Resort" />
        <Badge label="Nature Info" />
      </div>

      <!-- Blog Post List -->
      <div class="space-y-8">
        {
          posts.map((post) => (
            <a
              href={`/id/blog/${post.id}/`}
              class="group flex flex-col gap-4 rounded-2xl bg-white p-4 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md sm:flex-row sm:items-start"
            >
              {/* Thumbnail */}
              <div class="aspect-video w-full flex-shrink-0 overflow-hidden rounded-xl sm:w-48">
                {post.data.heroImage ? (
                  <Image
                    width={384}
                    height={216}
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-secondary/20 text-dark/30 text-xs">
                    No image
                  </div>
                )}
              </div>

              {/* Content */}
              <div class="flex-1">
                {post.data.category && <Badge label={post.data.category} variant="secondary" class="mb-2" />}
                <h3 class="font-heading text-xl font-bold text-dark group-hover:text-primary transition-colors">
                  {post.data.title}
                </h3>
                <p class="mt-1 text-sm text-dark/60 line-clamp-2">{post.data.description}</p>
                <div class="mt-3 text-xs text-dark/40">
                  <FormattedDate date={post.data.pubDate} />
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
