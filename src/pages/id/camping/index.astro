---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
---

<BaseLayout title="Camping">
  <section class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-6xl">
      <SectionHeader
        label="Camping Ground"
        title="Camping di Kasumi"
        subtitle="Dua pengalaman camping berbeda — pilih yang sesuai dengan jiwa petualangmu."
      />
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <p class="col-span-full text-center text-dark/50">Camping cards akan ditampilkan di sini — menunggu data dan foto.</p>
      </div>
    </div>
  </section>
</BaseLayout>
