---
/**
 * IntroSection — Brief orientation with large intro text + image carousel.
 * bg: --color-highlight. Text above, carousel below (or side-by-side on desktop).
 */
---

<section class="bg-highlight px-6 py-20 md:py-28 lg:py-32">
  <div class="mx-auto max-w-6xl">
    <!-- Intro Text -->
    <div class="mb-16 text-center" data-animate="fade-up">
      <p class="mx-auto max-w-3xl font-heading text-2xl leading-relaxed text-dark md:text-3xl lg:text-4xl">
        Villa di tengah hutan, camping ground dengan pemandangan pegunungan Sukabumi.
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-dark/60">
        A villa in the heart of the forest, a camping ground with mountain views in Sukabumi.
      </p>
    </div>

    <!-- Image Carousel Placeholder -->
    <div class="relative overflow-hidden" data-animate="fade-up">
      <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-px-6 pb-4 -mx-6 px-6 scrollbar-hide">
        <!-- 3 Placeholder images -->
        {[1, 2, 3].map((i) => (
          <div class="flex-shrink-0 snap-center">
            <div
              class="h-64 w-[500px] max-w-[80vw] rounded-2xl bg-secondary/20 flex items-center justify-center text-dark/30"
            >
              <span class="text-sm">Photo {i} — 600×400</span>
            </div>
          </div>
        ))}
      </div>
    </div>
    <!-- React Carousel island will replace the above in a future sprint -->
  </div>
</section>
