---
/**
 * FacilitiesSection — Reassures guests about comfort and amenities.
 * Headline + subtitle, then 3-column image-focused card grid.
 */
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'id') as Locale;
const t = useTranslations(locale);
const facilities = t.facilities.items;
---

<section class="bg-highlight px-6 py-28 md:py-32">
  <div class="mx-auto max-w-5xl">
    <!-- Section Header -->
    <div class="mb-14 text-center" data-animate="fade-up">
      <h2 class="font-heading text-3xl font-bold text-dark md:text-4xl lg:text-5xl">
        {t.facilities.headline}
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-dark/60 md:text-lg">
        {t.facilities.subtitle}
      </p>
    </div>

    <!-- Facility Cards Grid — 3 columns, tall image-focused cards -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-animate="stagger">
      {facilities.map((facility) => (
        <div class="group overflow-hidden rounded-2xl bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
          <!-- Image area — tall aspect ratio -->
          <div class="aspect-[3/4] overflow-hidden">
            <div
              class="h-full w-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
              style={`background-image: url('${facility.image}'); background-color: #e8e0d0;`}
            >
              <div class="flex h-full w-full items-end bg-gradient-to-t from-dark/30 to-transparent p-5">
                <div>
                  <h3 class="font-heading text-lg font-bold text-highlight">{facility.name}</h3>
                  <p class="mt-1 text-sm text-highlight/80">{facility.description}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
