---
/**
 * ActivitySection — Showcases 3 main activities: ATV, Campfire, Trekking.
 * Sticky left panel with section title, scrollable right column of activity cards.
 */
const activities = [
  {
    name: 'ATV Adventure',
    description: 'Jelajahi trek hutan dengan ATV — pengalaman memacu adrenalin di tengah alam Halimun Salak.',
  },
  {
    name: 'Api Unggun',
    description: 'Malam yang hangat bersama keluarga dan teman dengan api unggun di bawah langit berbintang.',
  },
  {
    name: 'Trekking',
    description: 'Telusuri jalur trekking di kawasan Taman Nasional Gunung Halimun Salak.',
  },
];
---

<section class="bg-secondary/10 overflow-hidden rounded-3xl mx-4 my-8 md:mx-8 lg:mx-12">
  <div class="flex flex-col lg:flex-row">

    <!-- Left Panel (Sticky) -->
    <div class="lg:sticky lg:top-24 lg:self-start lg:w-2/5 p-8 md:p-12 lg:p-16 bg-secondary rounded-3xl">
      <span class="mb-4 block text-sm font-semibold uppercase tracking-widest text-primary">
        Aktivitas
      </span>
      <h2 class="font-heading text-3xl font-bold leading-tight text-dark md:text-4xl">
        Aktivitas Seru untuk kamu dan Keluarga
      </h2>
    </div>

    <!-- Right Column (Scrollable Cards) -->
    <div class="flex-1 space-y-6 p-8 md:p-12 lg:p-16">
      {activities.map((activity) => (
        <div
          class="flex flex-col sm:flex-row items-start gap-6 rounded-2xl bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-md"
          data-animate="fade-up"
        >
          <!-- Activity Image Placeholder -->
          <div class="h-40 w-40 flex-shrink-0 rounded-xl bg-primary/10 flex items-center justify-center text-dark/30">
            <span class="text-xs">200×200</span>
          </div>
          <!-- Activity Info -->
          <div>
            <h3 class="font-heading text-xl font-bold text-dark">{activity.name}</h3>
            <p class="mt-2 text-dark/60">{activity.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
