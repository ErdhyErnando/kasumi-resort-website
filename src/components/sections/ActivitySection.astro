---
/**
 * ActivitySection — Showcases 3 main activities: ATV, Campfire, Trekking.
 * Sticky left panel with section title, scrollable right column of activity cards.
 * Green (#97BC62) background, rounded section block.
 */
import { getWhatsAppUrl } from '../../lib/whatsapp';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/utils';

const locale = (Astro.currentLocale ?? 'id') as Locale;
const t = useTranslations(locale);

const activityImages = [
  '/images/activity-atv.webp',
  '/images/activity-campfire.webp',
  '/images/activity-trekking.webp',
];

const activities = t.activity.items.map((item, i) => ({
  ...item,
  image: activityImages[i],
}));
---

<section class="px-4 py-24 md:px-8 lg:px-12 rounded-3xl bg-secondary">
  <div class="overflow-hidden">
    <div class="flex flex-col lg:flex-row">

      <!-- Left Panel (Sticky) -->
      <div class="p-8 md:p-10 lg:sticky lg:top-0 lg:self-start lg:w-[38%] lg:p-14">
        <h2 class="font-heading text-2xl font-bold leading-tight text-dark md:text-3xl lg:text-4xl">
          {t.activity.headingLine1}
          <br />{t.activity.headingLine2}
          <br />{t.activity.headingLine3}
        </h2>
      </div>

      <!-- Right Column (Scrollable Activity Items) -->
      <div class="flex-1 space-y-8 p-6 pt-0 md:p-10 md:pt-0 lg:p-14">
        {activities.map((activity) => (
          <div
            class="flex flex-col gap-5 sm:flex-row sm:items-start"
            data-animate="fade-up"
          >
            <!-- Activity Image -->
            <div class="h-90 w-full flex-shrink-0 overflow-hidden rounded-2xl sm:h-44 sm:w-44 md:h-48 md:w-48">
              <div
                class="h-full w-full bg-cover bg-center"
                style={`background-image: url('${activity.image}'); background-color: #7a9e4e;`}
              >
                <div class="flex h-full w-full items-center justify-center bg-primary/10 text-highlight/30">
                  <!-- <span class="text-xs">200×200</span> -->
                </div>
              </div>
            </div>

            <!-- Activity Info + Booking -->
            <div class="flex flex-2 flex-col justify-between sm:py-2">
              <div>
                <h3 class="font-heading text-xl font-bold text-dark md:text-2xl">{activity.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-dark/60 lg:max-w-sm">{activity.description}</p>
              </div>
              <a
                href={getWhatsAppUrl(activity.waMessage)}
                class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-dark/70 transition-colors hover:text-dark"
              >
                {t.activity.bookingLabel}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
