---
/**
 * LocationSection — Dark-themed card with embedded Google Map + text content.
 * Rounded dark card. Two-column: map embed left, text right.
 */
import { ADDRESS } from "../../lib/constants";
import { useTranslations } from "../../i18n/ui";
import type { Locale } from "../../i18n/utils";

const locale = (Astro.currentLocale ?? "id") as Locale;
const t = useTranslations(locale);
---

<section class="px-4 py-20 md:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl h-full">
        <div class="overflow-hidden rounded-3xl bg-dark" data-animate="fade-up">
            <div class="grid grid-cols-1 lg:grid-cols-2">
                <!-- Map Embed -->
                <div
                    class="flex items-center justify-start p-6 lg:p-8 min-h-[450px] lg:min-h-[600px]"
                >
                    <div
                        class="w-full h-full min-h-[380px] lg:min-h-[500px] rounded-xl overflow-hidden border border-white/80! ring-1! ring-white/5! shadow-lg"
                    >
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1588.0!2d106.716366!3d-6.74877!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69d3f85ae8cd67%3A0xd9d73a79a3daa796!2sKASUMI%20Resorts%20-%20Enjoy%20Living!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
                            width="100%"
                            height="100%"
                            class="block w-full h-full"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Kasumi Resort Location"
                        >
                        </iframe>
                    </div>
                </div>

                <!-- Text Content -->
                <div class="flex flex-col justify-center p-8 md:p-10 lg:p-14">
                    <h2
                        class="font-heading text-3xl font-bold leading-tight text-accent! md:text-4xl"
                    >
                        <span class="block">{t.location.line1}</span>
                        <span class="block">{t.location.line2}</span>
                    </h2>

                    <div
                        class="mt-8 space-y-3 text-md text-highlight/70! md:text-base"
                    >
                        <p>{t.location.distanceJakarta}</p>
                        <p>{t.location.distanceBogor}</p>
                    </div>

                    <a
                        href="https://maps.google.com/?q=TNGHS+Cidahu+Sukabumi+Jawa+Barat+43358"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mt-8 inline-flex items-center gap-2 text-md font-medium text-highlight/90! underline underline-offset-4 decoration-highlight/70! transition-colors! hover:text-highlight! hover:decoration-highlight/60! hover:cursor-pointer"
                    >
                        {ADDRESS}
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                            ></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
