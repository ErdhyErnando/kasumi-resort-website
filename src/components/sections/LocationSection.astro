---
/**
 * LocationSection — Dark-themed card with embedded Google Map + text content.
 * Two-column inside: map embed left, text right.
 */
import { ADDRESS } from '../../lib/constants';
---

<section class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-6xl">
    <div
      class="overflow-hidden rounded-3xl bg-dark"
      data-animate="fade-up"
    >
      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Map Embed -->
        <div class="aspect-square lg:aspect-auto">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15845.0!2d106.6885!3d-6.7415!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwNDQnMjkuNCJTIDEwNsKwNDEnMTguNiJF!5e0!3m2!1sid!2sid!4v1"
            width="100%"
            height="100%"
            style="border:0; min-height: 400px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Kasumi Resort Location"
          ></iframe>
        </div>

        <!-- Text Content -->
        <div class="flex flex-col justify-center p-8 md:p-12 lg:p-16">
          <h2 class="font-heading text-3xl font-bold leading-tight text-highlight md:text-4xl lg:text-5xl">
            <span class="block">Close to the city</span>
            <span class="block text-accent">Far from noise</span>
          </h2>

          <div class="mt-8 space-y-4 text-highlight/70">
            <p class="flex items-center gap-3">
              <span class="text-accent">📍</span>
              2 hours from Jakarta
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent">📍</span>
              1.5 hours from Bogor
            </p>
          </div>

          <a
            href="https://maps.google.com/?q=TNGHS+Cidahu+Sukabumi+Jawa+Barat+43358"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex items-center gap-2 text-sm text-accent underline underline-offset-4 transition-colors hover:text-accent/80"
          >
            {ADDRESS}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
