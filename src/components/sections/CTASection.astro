---
/**
 * CTASection — Pre-footer call-to-action. Large bold text + single prominent button.
 */
import Button from '../ui/Button.astro';
import { getWhatsAppUrl } from '../../lib/whatsapp';
---

<section class="bg-highlight px-6 py-24 md:py-32">
  <div class="mx-auto max-w-4xl text-center" data-animate="fade-up">
    <h2
      class="font-heading text-4xl font-bold leading-tight text-dark md:text-5xl lg:text-6xl"
    >
      Ready To Leave The City Behind?
    </h2>

    <div class="mt-10">
      <Button
        label="Booking"
        href={getWhatsAppUrl()}
        variant="accent"
        size="lg"
      />
    </div>
  </div>
</section>
